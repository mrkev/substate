{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2025", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true
  },
  "files": [],
  "include": [],

  "references": [
    { "path": "./packages/site" },
    { "path": "./packages/old-state" },
    { "path": "./packages/structured-state" },
    { "path": "./packages/linked-state" },
    { "path": "./packages/marked-subbable" },
    { "path": "./packages/marked-serializable" }
  ]
}
